{
  "name": "data-unit-converter",
  "description": "A simple data unit converter",
  "version": "1.2.3",
  "author": "Jhordy Gavinchu",
  "keywords": [
    "react",
    "data-conversion",
    "mathjs",
    "typescript"
  ],
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "start": "vite preview",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "ts-check": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "validate": "pnpm lint && pnpm ts-check && pnpm test --run",
    "format": "prettier --write .",
    "prepare": "husky",
    "postinstall": "pnpm audit --audit-level moderate"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.23.1",
    "mathjs": "^15.1.1",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-select": "^5.10.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
